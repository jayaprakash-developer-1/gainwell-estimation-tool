                                                    <Button Content="+" Width="28" Height="28" FontSize="14" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="OnSysDocIncrement" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <!-- Communication Plan -->
                                    <Border Background="#F5F6FA" CornerRadius="6" Padding="12,10" BorderBrush="#D4D7E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="?? Communication Plan" FontSize="12" FontWeight="Medium" />
                                                <TextBlock Text="Insert time needed to create a Communication Plan" FontSize="10" Foreground="#5A6978" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="1" BorderBrush="#D4D7E0" BorderThickness="1" CornerRadius="6" Background="#F5F6FA" Padding="4,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="-" Width="28" Height="28" FontSize="14" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="OnCommPlanDecrement" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                                    <TextBox x:Name="CommPlanHoursTextBox" Text="0" Width="70" Padding="4,4" FontSize="13" TextAlignment="Center" BorderThickness="0" Background="Transparent" TextChanged="OnSummaryFieldChanged" VerticalContentAlignment="Center" />
                                                    <Button Content="+" Width="28" Height="28" FontSize="14" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="OnCommPlanIncrement" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Section 6: Assumptions -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Assumptions" Style="{StaticResource SectionHeader}" />
                                    <TextBox x:Name="BaAssumptionsDetailTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="80" Padding="8,6" FontSize="12"
                                             MaxLength="4000"
                                             TextChanged="OnBaAssumptionsTextChanged" />
                                    <TextBlock x:Name="BaAssumptionsCounter" Text="0 / 4000"
                                               FontSize="9" HorizontalAlignment="Right" Foreground="#5A6978" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Section 7: Additional Hours Notes -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="*Additional Hours Notes (i.e. BDD revisions and special considerations on testing)" Style="{StaticResource SectionHeader}" />
                                    <TextBox x:Name="BaAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="80" Padding="8,6" FontSize="12"
                                             MaxLength="4000"
                                             TextChanged="OnBaAdjNotesTextChanged" />
                                    <TextBlock x:Name="BaAdjNotesCounter" Text="0 / 4000"
                                               FontSize="9" HorizontalAlignment="Right" Foreground="#5A6978" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Hidden DataGrids (preserve existing model binding for calculations) -->
                            <DataGrid x:Name="BaTestCasesGrid" Visibility="Collapsed" AutoGenerateColumns="False" CanUserAddRows="False" />
                            <DataGrid x:Name="BaRegressionGrid" Visibility="Collapsed" AutoGenerateColumns="False" CanUserAddRows="False" />
                            <DataGrid x:Name="BaProductionValidationGrid" Visibility="Collapsed" AutoGenerateColumns="False" CanUserAddRows="False" />

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab 4: Collaboration/Quality -->
            <TabItem Header="?? Collaboration/Quality">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <!-- Collaboration heading with Estimate By on the right -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Collaboration � Quality" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
                                    <TextBlock Grid.Column="2" Text="Estimate By:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="CollabEstimateByTextBox" Grid.Column="3" Padding="8,6" FontSize="13" Width="200" />
                                </Grid>

                                <!-- Instructions (Excel R5) -->
                                <TextBlock Text="All fields highlighted below are input fields. Adjust values to match your project's collaboration and quality requirements." 
                                           FontSize="11" Foreground="#5A6978" TextWrapping="Wrap" Margin="0,0,0,12" />

                                <!-- Total Summary at TOP (Excel R12) -->
                                <Border Background="#FDF8EF" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Total Summary" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="Hour Total" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="CollabHourTotalTopText" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2B3A44" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="Adjusted" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="CollabAdjTotalTopText" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2B3A44" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="Grand Total" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="CollabGrandTotalTopText" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Column Headers for Meeting Sections -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Task" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" />
                                    <TextBlock Grid.Column="1" Text="Count" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="Hours" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="# Attendees" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="Hour Total" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="5" Text="Adjusted Hrs" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="6" Text="Grand Total" FontSize="11" FontWeight="SemiBold" Foreground="#5A6978" HorizontalAlignment="Center" />
                                </Grid>

                                <!-- WPRs -->
                                <Border Background="#EBEDF5" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- WPR Meetings: G14 = B14 * 1 * E14 (Count +� MtgHrs +� Attendees) -->
                                        <TextBlock Grid.Row="0" Text="Walkthrough/Work Product Reviews" FontSize="13" VerticalAlignment="Center"
                                                   ToolTip="Insert the number of Gainwell walkthroughs and/or work product reviews expected over the remainder of the work item. This should include meetings like TDD, Code Reviews, etc." />
                                        <TextBox x:Name="WprCountTextBox" Grid.Row="0" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="WprHoursTextBox" Grid.Row="0" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="WprAttendeesTextBox" Grid.Row="0" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="WprTotalText" Grid.Row="0" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBox x:Name="WprAdjustedTextBox" Grid.Row="0" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="WprGrandTotalText" Grid.Row="0" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <!-- WPR Prep: G15 = C15 * E14 * B14 (PrepHrs +� Attendees +� Count) -->
                                        <TextBlock Grid.Row="1" Text="  WPR Preparation per person" FontSize="12" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,6,0,0"
                                                   ToolTip="Enter the number of preparation hours required for each person." />
                                        <TextBox x:Name="WprPrepHoursTextBox" Grid.Row="1" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="WprPrepTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="WprPrepAdjustedTextBox" Grid.Row="1" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="WprPrepGrandTotalText" Grid.Row="1" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Client Meetings -->
                                <Border Background="#EBEDF5" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Client: G17 = B17 * 1 * E17 -->
                                        <TextBlock Grid.Row="0" Text="Client Meetings" FontSize="13" VerticalAlignment="Center"
                                                   ToolTip="Insert the number of client meetings expected over the remainder of the work item. This should include joint review meetings (requirements clarification, BDD reviews, educational meetings, etc)." />
                                        <TextBox x:Name="ClientMtgCountTextBox" Grid.Row="0" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="ClientMtgHoursTextBox" Grid.Row="0" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="ClientMtgAttendeesTextBox" Grid.Row="0" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="ClientMtgTotalText" Grid.Row="0" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBox x:Name="ClientMtgAdjustedTextBox" Grid.Row="0" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="ClientMtgGrandTotalText" Grid.Row="0" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <!-- Client Prep: G18 = C18 * E17 * B17 -->
                                        <TextBlock Grid.Row="1" Text="  Client Meeting Prep per person" FontSize="12" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,6,0,0"
                                                   ToolTip="Enter the number of preparation hours required for each person." />
                                        <TextBox x:Name="ClientMtgPrepHoursTextBox" Grid.Row="1" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="ClientMtgPrepTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="ClientMtgPrepAdjustedTextBox" Grid.Row="1" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="ClientMtgPrepGrandTotalText" Grid.Row="1" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Internal Meetings -->
                                <Border Background="#EBEDF5" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Internal: G20 = B20 * 1 * E20 -->
                                        <TextBlock Grid.Row="0" Text="Internal Meetings" FontSize="13" VerticalAlignment="Center"
                                                   ToolTip="Insert the number of internal Gainwell meetings (team/status meetings, issue resolution, consultant meetings, etc.) expected over the remainder of the work item." />
                                        <TextBox x:Name="InternalMtgCountTextBox" Grid.Row="0" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="InternalMtgHoursTextBox" Grid.Row="0" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBox x:Name="InternalMtgAttendeesTextBox" Grid.Row="0" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="InternalMtgTotalText" Grid.Row="0" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBox x:Name="InternalMtgAdjustedTextBox" Grid.Row="0" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="InternalMtgGrandTotalText" Grid.Row="0" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <!-- Internal Prep: G21 = C21 * E20 * B20 -->
                                        <TextBlock Grid.Row="1" Text="  Internal Meeting Prep per person" FontSize="12" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,6,0,0"
                                                   ToolTip="Enter the number of preparation hours required for each person." />
                                        <TextBox x:Name="InternalMtgPrepHoursTextBox" Grid.Row="1" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="InternalMtgPrepTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="InternalMtgPrepAdjustedTextBox" Grid.Row="1" Grid.Column="5" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="InternalMtgPrepGrandTotalText" Grid.Row="1" Grid.Column="6" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Consultant/Mentor -->
                                <Border Background="#EBEDF5" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Consultant/Mentor Effort" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock x:Name="ConsultantTotalText" Grid.Column="1" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" />
                                        </Grid>
                                        <TextBlock Text="Insert Consultant names below and associated hours." FontSize="11" Foreground="#5A6978" Margin="0,0,0,8" />
                                        <DataGrid x:Name="ConsultantGrid" AutoGenerateColumns="False"
                                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                  BorderThickness="1" BorderBrush="#D4D7E0"
                                                  RowHeight="32" MinHeight="80" MaxHeight="200"
                                                  CellEditEnding="OnConsultantCellEditEnding">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Person Name" Binding="{Binding Name}" Width="200" />
                                                <DataGridTextColumn Header="Hours" Binding="{Binding Hours}" Width="100" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Create Estimates & PM -->
                                <Border Background="#EBEDF5" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Create Detailed and Final Estimates" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock x:Name="EstimatesTotalText" Grid.Row="0" Grid.Column="2" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Text="  Create Detailed Estimate (hrs):" FontSize="12" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,6,0,0"
                                                   ToolTip="Insert the number of hours to create the Detailed Estimate." />
                                        <TextBox x:Name="CreateDetailEstHoursTextBox" Grid.Row="1" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />

                                        <TextBlock Grid.Row="2" Text="  Create Final Estimate (hrs):" FontSize="12" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,6,0,0"
                                                   ToolTip="Insert the number of hours to create the Final Estimate." />
                                        <TextBox x:Name="CreateFinalEstHoursTextBox" Grid.Row="2" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" TextChanged="OnCollabFieldChanged" />

                                        <TextBlock Grid.Row="3" Text="Project Manager Effort (hrs):" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,10,0,0"
                                                   ToolTip="Insert the number of PM hours required." />
                                        <TextBox x:Name="PmEffortHoursTextBox" Grid.Row="3" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,10,4,0" TextChanged="OnCollabFieldChanged" />
                                        <TextBlock x:Name="PmEffortTotalText" Grid.Row="3" Grid.Column="2" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Collaboration Total Summary -->
                                <Border Background="#EDF0F8" CornerRadius="6" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Total Collaboration/Quality:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CollabHourTotalText" Grid.Column="1" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#2B3A44" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CollabAdjTotalText" Grid.Column="2" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#2B3A44" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CollabTotalText" Grid.Column="3" Text="0.00" 
                                                   FontSize="16" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Assumptions -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Assumptions" Style="{StaticResource SectionHeader}" />
                                <TextBlock Text="Add assumptions that led to the numbers in the estimate." FontSize="11" Foreground="#5A6978" Margin="0,0,0,6" />
                                <TextBox x:Name="CollabAssumptionsDetailTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="100" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Adjusted Hours Assumption -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="*Additional Hours Notes" Style="{StaticResource SectionHeader}" />
                                <TextBlock Text="Add justification for adjusted hours (i.e. BRD revisions and approvals)." FontSize="11" Foreground="#5A6978" Margin="0,0,0,6" />
                                <TextBox x:Name="CollabAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="100" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
