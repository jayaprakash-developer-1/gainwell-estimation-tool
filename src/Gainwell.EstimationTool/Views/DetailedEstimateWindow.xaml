                                        <Border Grid.Row="3" Grid.ColumnSpan="3" Background="#FDF8EF" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="100" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Project Manager Effort (hrs)" FontFamily="Arial" FontSize="12" FontWeight="SemiBold" Foreground="#2B3A44" VerticalAlignment="Center"
                                                           ToolTip="Insert the number of PM hours required. In Detailed Estimates this is a direct hour input (not a percentage)." />
                                                <TextBox x:Name="PmEffortHoursTextBox" Grid.Column="1" Text="0" Padding="6,4" FontFamily="Arial" FontSize="12" Margin="4,0" HorizontalContentAlignment="Center" TextChanged="OnCollabFieldChanged" />
                                                <TextBlock x:Name="PmEffortTotalText" Grid.Column="2" Text="0.00" FontFamily="Arial" FontSize="12" FontWeight="Bold" Foreground="#55206E" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- BOTTOM TOTAL SUMMARY -->
                        <Border CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1931E3" Offset="0" />
                                    <GradientStop Color="#2E307A" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL COLLABORATION / QUALITY" FontFamily="Arial" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                                <TextBlock x:Name="CollabHourTotalText" Grid.Column="1" Text="0.00" FontFamily="Arial" FontSize="14" FontWeight="Bold" Foreground="#00EEAE" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock x:Name="CollabAdjTotalText" Grid.Column="2" Text="0.00" FontFamily="Arial" FontSize="14" FontWeight="Bold" Foreground="#CC1AC7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock x:Name="CollabTotalText" Grid.Column="3" Text="0.00" FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- ASSUMPTIONS -->
                        <Border Background="White" CornerRadius="8" Padding="0" Margin="0,0,0,12" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.04" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#8E99A8" CornerRadius="8,0,0,8" />
                                <StackPanel Grid.Column="1" Margin="16,14">
                                    <TextBlock Text="Assumptions" FontFamily="Arial" FontSize="13" FontWeight="Bold" Foreground="#2B3A44" Margin="0,0,0,4" />
                                    <TextBlock Text="Add assumptions that led to the numbers in the estimate." FontFamily="Arial" FontSize="11" Foreground="#8E99A8" Margin="0,0,0,8" />
                                    <TextBox x:Name="CollabAssumptionsDetailTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="100" Padding="8,6" FontFamily="Arial" FontSize="12"
                                             BorderBrush="#D4D7E0" />
                                    <TextBlock x:Name="CollabAssumptionsCharCount" Text="0/2000" FontFamily="Arial" FontSize="9" Foreground="#8E99A8" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ADDITIONAL HOURS NOTES -->
                        <Border Background="White" CornerRadius="8" Padding="0" Margin="0,0,0,12" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.04" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#CC1AC7" CornerRadius="8,0,0,8" />
                                <StackPanel Grid.Column="1" Margin="16,14">
                                    <TextBlock Text="*Additional Hours Notes" FontFamily="Arial" FontSize="13" FontWeight="Bold" Foreground="#2B3A44" Margin="0,0,0,4" />
                                    <TextBlock Text="Add justification for adjusted hours (i.e. BRD revisions and approvals)." FontFamily="Arial" FontSize="11" Foreground="#8E99A8" Margin="0,0,0,8" />
                                    <TextBox x:Name="CollabAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="100" Padding="8,6" FontFamily="Arial" FontSize="12"
                                             BorderBrush="#D4D7E0" />
                                    <TextBlock x:Name="CollabAdjNotesCharCount" Text="0/2000" FontFamily="Arial" FontSize="9" Foreground="#8E99A8" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
