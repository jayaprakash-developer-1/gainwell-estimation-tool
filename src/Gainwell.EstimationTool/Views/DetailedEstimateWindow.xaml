                                            </StackPanel>
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                                <TextBlock Text="Complex" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryComplex" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                                <TextBlock Text="V.Complex" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryVeryComplex" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                                                <TextBlock Text="Complexity Total" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryCT" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                                <TextBlock Text="Adj Exp Lvl" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryAdjExp" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="7" HorizontalAlignment="Center">
                                                <TextBlock Text="Adj Hrs" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryAdjHrs" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="8" HorizontalAlignment="Center">
                                                <TextBlock Text="Grand Total" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummaryGrandTotal" Text="0" FontSize="11" FontWeight="Bold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- New to Area Expander -->
