<Window x:Class="Gainwell.EstimationTool.Views.DetailedEstimateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detailed Estimate" 
        Height="1000" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#EBEDF5"
        Icon="/Assets/app.ico"
        KeyboardNavigation.TabNavigation="Cycle">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="OnSaveCommand" />
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}" Executed="OnUndoCommand" />
    </Window.CommandBindings>

    <Window.Resources>
        <!-- Implicit TextBox style: "0" shows as subtle placeholder, entered values are bold (only for single-line numeric fields) -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="AcceptsReturn" Value="False">
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Text" Value="0" />
                        <Condition Property="AcceptsReturn" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="#C2C6D2" />
                    <Setter Property="FontWeight" Value="Normal" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- ToolTip style with text wrapping — matches InitialEstimateWindow -->
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Placement" Value="Right" />
            <Setter Property="HorizontalOffset" Value="4" />
            <Setter Property="VerticalOffset" Value="-4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#2B3A44" CornerRadius="8" Padding="12,10"
                                BorderBrush="#5A6978" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" Opacity="0.28" ShadowDepth="4" Direction="270" Color="#000000" />
                            </Border.Effect>
                            <ContentPresenter>
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="FontFamily" Value="Arial" />
                                        <Setter Property="LineHeight" Value="20" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Arial" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Opened">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Padding="24,16" Margin="8,8,8,0" CornerRadius="8,8,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#019681" Offset="0" />
                    <GradientStop Color="#1A6478" Offset="0.5" />
                    <GradientStop Color="#2E307A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <Image Source="/Assets/logo.png" Height="36" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Detailed Estimate" FontFamily="Arial" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="16,8" Margin="8,0" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TotalHoursKpi" Text="0.00 Hrs" FontFamily="Arial" FontSize="18" FontWeight="Bold" Foreground="#019681" HorizontalAlignment="Center" />
                        <TextBlock Text="Total Hours" FontFamily="Arial" FontSize="10" Foreground="#5A6978" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}" 
                            Click="OnHomeClick" Margin="4,0"
                            Foreground="White" BorderBrush="#2199B0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Home" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =========== ESTIMATE TAB NAVIGATION =========== -->
        <Border Grid.Row="1" Margin="8,0,8,0" Padding="4,4" Background="#EBEDF5" CornerRadius="0,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Navigation Tabs (Left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <!-- Initial Estimate Tab -->
                    <Border x:Name="InitialTab" Background="Transparent" CornerRadius="6" Padding="16,8" Margin="4,0"
                            Cursor="Hand" MouseLeftButtonDown="OnInitialTabClick">
                        <TextBlock Text="Initial Estimate" FontSize="12" FontWeight="SemiBold" Foreground="#5A6978" />
                    </Border>
                    <!-- Detailed Estimate Tab (Active) -->
                    <Border Background="#1931E3" CornerRadius="6" Padding="16,8" Margin="4,0">
                        <TextBlock Text="Detailed Estimate" FontFamily="Arial" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                    <!-- Final Estimate Tab -->
                    <Border Background="Transparent" CornerRadius="6" Padding="16,8" Margin="4,0"
                            Cursor="Hand" MouseLeftButtonDown="OnFinalTabClick">
                        <TextBlock Text="Final Estimate" FontSize="12" FontWeight="SemiBold" Foreground="#8E99A8" />
                    </Border>
                </StackPanel>

                <!-- Save & Settings Buttons (Right) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="1" Background="#D4D7E0" Margin="8,4" />
                    <Button Style="{StaticResource GhostButton}" 
                            Click="OnSaveClick" Margin="4,0" ToolTip="Ctrl+S">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Settings" Style="{StaticResource GhostButton}" 
                            Click="OnSettingsClick" Margin="4,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control for 4 Sub-Pages -->
        <TabControl Grid.Row="2" Margin="8,8,8,8" BorderThickness="0" Background="Transparent"
                   SelectionChanged="OnTabSelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,10" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="#5A6978" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}" 
                                        Background="Transparent" CornerRadius="6,6,0,0"
                                        BorderThickness="0,0,0,3" BorderBrush="Transparent" Margin="2,0">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#019681" />
                                        <Setter Property="Foreground" Value="#019681" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#F5F6FA" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Summary -->
            <TabItem Header="Estimate Summary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Project Header Card with gradient accent -->
                        <Border CornerRadius="12" Margin="8" Padding="0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.06" ShadowDepth="3" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <!-- Top accent bar -->
                                <Border Height="4" VerticalAlignment="Top" CornerRadius="12,12,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#019681" Offset="0" />
                                            <GradientStop Color="#1931E3" Offset="0.5" />
                                            <GradientStop Color="#2E307A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="PROJECT NAME" FontSize="10" FontWeight="SemiBold" Foreground="#8E99A8" Margin="0,0,0,6" />
                                            <TextBox x:Name="ProjectNameTextBox" Padding="10,8" FontSize="13" IsReadOnly="True" Background="#F5F6FA" BorderBrush="#D4D7E0" BorderThickness="1"
                                                     ToolTip="The name of the project being estimated">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Text="CHANGE ORDER / DEFECT" FontSize="10" FontWeight="SemiBold" Foreground="#8E99A8" Margin="0,0,0,6" />
                                            <TextBox x:Name="ChangeOrderTextBox" Padding="10,8" FontSize="13" IsReadOnly="True" Background="#F5F6FA" BorderBrush="#D4D7E0" BorderThickness="1"
                                                     ToolTip="Change Order ID or Defect number associated with this estimate">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                            <TextBlock Text="DATE (MM/DD/YYYY)" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,6" />
                                            <TextBox x:Name="ActualHoursDateTextBox" Padding="10,8" FontSize="13" BorderBrush="#D4D7E0" BorderThickness="1" Tag="text"
                                                     ToolTip="Date when the actual hours were recorded (format: MM/DD/YYYY)">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!--  KPI METRIC CARDS  -->
                        <Grid Margin="8,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Actual Hours Card -->
                            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Enter the total actual hours spent on this project">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="ACTUAL HOURS" FontSize="9" FontWeight="Bold" Foreground="#8E99A8" Margin="0,0,0,4" />
                                    <TextBox x:Name="ActualHoursTextBox" Text="0" Padding="0" FontSize="20" FontWeight="Bold" Foreground="#2B3A44" 
                                             BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Left" TextChanged="OnSummaryFieldChanged" />
                                </StackPanel>
                            </Border>

                            <!-- SE Hours Card -->
                            <Border Grid.Column="1" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total hours estimated by Software Engineering (auto-calculated from SE tab)">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E6F5F2" Offset="0" />
                                        <GradientStop Color="#E6F5F2" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#E6F5F2" HorizontalAlignment="Left" />
                                        <TextBlock Text="&#xE74C;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#019681" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="SE HOURS" FontFamily="Arial" FontSize="9" FontWeight="Bold" Foreground="#019681" Margin="0,0,0,4" />
                                    <TextBlock x:Name="SeHoursKpi" Text="0.00" FontFamily="Arial" FontSize="20" FontWeight="Bold" Foreground="#019681" />
                                </StackPanel>
                            </Border>

                            <!-- BA Hours Card -->
                            <Border Grid.Column="2" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total hours estimated by Business Analyst (auto-calculated from BA tab)">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EDF0F8" Offset="0" />
                                        <GradientStop Color="#EDF0F8" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="BA HOURS" FontSize="9" FontWeight="Bold" Foreground="#2E307A" Margin="0,0,0,4" />
                                    <TextBlock x:Name="BaHoursKpi" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#1931E3" />
                                </StackPanel>
                            </Border>

                            <!-- Collaboration Hours Card -->
                            <Border Grid.Column="3" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total Collaboration/Quality hours including meetings, WPRs, and mentoring">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FDF8EF" Offset="0" />
                                        <GradientStop Color="#FDF8EF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="COLLAB HOURS" FontSize="9" FontWeight="Bold" Foreground="#5A6978" Margin="0,0,0,4" />
                                    <TextBlock x:Name="CollabHoursKpi" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#E5AB4F" />
                                </StackPanel>
                            </Border>

                            <!-- Total Estimate Card -->
                            <Border Grid.Column="4" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Grand total of all estimated hours including PM reserve">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E6F5F2" Offset="0" />
                                        <GradientStop Color="#E6F5F2" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="3" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#00EEAE" HorizontalAlignment="Left" />
                                        <TextBlock Text="S" FontSize="16" FontWeight="Bold" Foreground="#019681" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="TOTAL ESTIMATE" FontSize="9" FontWeight="Bold" Foreground="#2B3A44" Margin="0,0,0,4" />
                                    <TextBlock x:Name="TotalWithReserveText" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#019681" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- PM Reserve Row -->
                        <Border Background="White" CornerRadius="10" Padding="16,12" Margin="12,0,12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.04" ShadowDepth="1" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#EDF0F8" CornerRadius="6" Padding="8,4" Margin="0,0,12,0">
                                        <TextBlock Text="PM" FontFamily="Arial" FontSize="10" FontWeight="Bold" Foreground="#55206E" />
                                    </Border>
                                    <TextBlock Text="Project Management Reserve" FontFamily="Arial" FontSize="13" FontWeight="SemiBold" Foreground="#2B3A44" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox x:Name="PmReserveTextBox" Text="5" Width="48" Padding="6,4" FontSize="12" TextAlignment="Center" 
                                             BorderBrush="#D4D7E0" TextChanged="OnSummaryFieldChanged"
                                             ToolTip="Percentage of total hours to reserve for Project Management (typically 5-10%)">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock Text=" %" FontSize="13" Foreground="#5A6978" VerticalAlignment="Center" Margin="2,0,16,0" />
                                    <Border Background="#F5F3FF" CornerRadius="6" Padding="10,4">
                                        <TextBlock x:Name="PmReserveHoursText" Text="0.00 hrs" FontSize="13" FontWeight="Bold" Foreground="#1931E3" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  TEAM / ESTIMATED BY  -->
                        <Border Background="White" CornerRadius="10" Padding="20,16" Margin="12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.05" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="TEAM" FontSize="10" FontWeight="Bold" Foreground="#8E99A8" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F5F6FA" CornerRadius="8" Padding="12,10" Margin="0,0,6,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#019681" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="SE ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#5A6978" />
                                            </StackPanel>
                                            <TextBox x:Name="EstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#D4D7E0" BorderThickness="1" Tag="text">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#F5F6FA" CornerRadius="8" Padding="12,10" Margin="3,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#1931E3" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="BA ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#5A6978" />
                                            </StackPanel>
                                            <TextBox x:Name="BaEstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#D4D7E0" BorderThickness="1" Tag="text">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#F5F6FA" CornerRadius="8" Padding="12,10" Margin="6,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#E5AB4F" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="COLLAB ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#5A6978" />
                                            </StackPanel>
                                            <TextBox x:Name="CollabEstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#D4D7E0" BorderThickness="1" Tag="text">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!--  ASSUMPTIONS  -->
                        <Border Background="White" CornerRadius="10" Padding="20,16" Margin="12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.05" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="ASSUMPTIONS" FontSize="10" FontWeight="Bold" Foreground="#8E99A8" Margin="0,0,0,14" />
                                <!-- SE Assumption -->
                                <Border Background="#E6F5F2" CornerRadius="8" Padding="14,10" Margin="0,0,0,10" BorderBrush="#019681" BorderThickness="1,1,1,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Ellipse Width="8" Height="8" Fill="#019681" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="SE Assumption" FontSize="11" FontWeight="SemiBold" Foreground="#166534" />
                                        </StackPanel>
                                        <TextBlock x:Name="SummarySeAssumptionText" TextWrapping="Wrap" FontSize="12" Foreground="#2B3A44" FontStyle="Italic" />
                                    </StackPanel>
                                </Border>
                                <!-- BA Assumption -->
                                <Border Background="#EDF0F8" CornerRadius="8" Padding="14,10" Margin="0,0,0,10" BorderBrush="#C2C6D2" BorderThickness="1,1,1,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Ellipse Width="8" Height="8" Fill="#1931E3" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="BA Assumption" FontSize="11" FontWeight="SemiBold" Foreground="#2E307A" />
                                        </StackPanel>
                                        <TextBlock x:Name="SummaryBaAssumptionText" TextWrapping="Wrap" FontSize="12" Foreground="#2B3A44" FontStyle="Italic" />
                                    </StackPanel>
                                </Border>
                                <!-- Collab Assumption -->
                                <Border Background="#FDF8EF" CornerRadius="8" Padding="14,10" BorderBrush="#E5AB4F" BorderThickness="1,1,1,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
