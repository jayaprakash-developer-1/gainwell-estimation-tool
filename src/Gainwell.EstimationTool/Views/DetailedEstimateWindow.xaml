                                                                    <TextBlock Text="Moderate" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                                                    <Border BorderBrush="#E5AB4F" BorderThickness="1" CornerRadius="4" Background="#FDF8EF" Padding="2">
