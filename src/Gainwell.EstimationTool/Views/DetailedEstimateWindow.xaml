                                    <TextBlock Text="Adj Hrs:" FontFamily="Arial" FontSize="10" Foreground="#00EEAE" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock x:Name="BaGrandTotalAdjHrs" Text="0.00" FontFamily="Arial" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- SCROLLABLE CONTENT -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel Margin="8">

                            <!-- BA Header: title + Change Order + BA Estimate By -->
                            <Border Style="{StaticResource CardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="BA Estimate &#x2014; Testing/Documentation" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
