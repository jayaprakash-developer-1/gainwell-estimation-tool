                                    </StackPanel>
                                    <Expander IsExpanded="False" Margin="0,0,0,8">
                                        <Expander.Header>
                                            <TextBlock Text="Instructions" FontSize="11" Foreground="#5A6978" />
                                        </Expander.Header>
                                        <TextBlock FontSize="11" Foreground="#5A6978" TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Text="Ideally at the time of submitting the detail estimate, there will be zero hours left on BDD creation, since the BDD work must have been complete at this point in time. There may be cases where a conditional approval is granted requesting BDD updates and a new version of the BDD is *not* requested. In such cases, the remaining BDD work may be entered here and the overall hours can be submitted to the data librarians (Only if the hours are *not* included in the Actual hours in the Dtl EstimateSummary)." />
                                    </Expander>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Remaining BDD Hours:" FontSize="13" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" BorderBrush="#D4D7E0" BorderThickness="1" CornerRadius="6" Background="#F5F6FA" Padding="4,2">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="-" Width="28" Height="28" FontSize="14" FontWeight="Bold"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Click="OnBddDecrement" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                                <TextBox x:Name="RemainingBddHoursTextBox" Text="0" Width="70"
                                                         Padding="4,4" FontSize="13" TextAlignment="Center"
                                                         BorderThickness="0" Background="Transparent"
                                                         TextChanged="OnSummaryFieldChanged" VerticalContentAlignment="Center" />
                                                <Button Content="+" Width="28" Height="28" FontSize="14" FontWeight="Bold"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Click="OnBddIncrement" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: Write System Test Cases � Grouped by Experience Level -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Write System Test Cases" Style="{StaticResource SectionHeader}" />

                                    <!-- WTC Summary strip -->
                                    <Border Background="#F5F6FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,12"
                                            BorderBrush="#C2C6D2" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Write System Test Cases Summary" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="Simple" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
                                                <TextBlock x:Name="BaTcSummarySimple" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="Moderate" FontSize="9" Foreground="#2199B0" HorizontalAlignment="Center" />
