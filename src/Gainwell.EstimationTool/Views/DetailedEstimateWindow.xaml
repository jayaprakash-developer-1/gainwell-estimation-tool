                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Write System Test Cases -->
                                                <Border Background="White" CornerRadius="6" Padding="12,10" Margin="0,0,0,6"
                                                        BorderBrush="#D4D7E0" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="Write System Test Cases (# cases)" FontSize="12" FontWeight="Medium" Margin="0,0,0,8" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <StackPanel Margin="0,0,12,0">
                                                                    <TextBlock Text="Simple" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                                                    <Border BorderBrush="#00EEAE" BorderThickness="1" CornerRadius="4" Background="#E6F5F2" Padding="2">
                                                                        <TextBox x:Name="BaNewWTC_Simple" Text="0" Width="50" TextAlignment="Center" FontSize="12"
                                                                                 BorderThickness="0" Background="Transparent" TextChanged="OnBaCardValueChanged" />
