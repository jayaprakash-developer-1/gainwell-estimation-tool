                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="Understanding Requirements" FontSize="12" FontWeight="Medium" Margin="0,0,0,8" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <StackPanel Margin="0,0,12,0">
                                                                    <TextBlock Text="Simple" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                                                    <Border BorderBrush="#00EEAE" BorderThickness="1" CornerRadius="4" Background="#E6F5F2" Padding="2">
                                                                        <TextBox x:Name="BaNewUR_Simple" Text="0" Width="50" TextAlignment="Center" FontSize="12"
                                                                                 BorderThickness="0" Background="Transparent" TextChanged="OnBaCardValueChanged" />
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Margin="0,0,12,0">
                                                                    <TextBlock Text="Moderate" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                                                    <Border BorderBrush="#E5AB4F" BorderThickness="1" CornerRadius="4" Background="#FDF8EF" Padding="2">
                                                                        <TextBox x:Name="BaNewUR_Moderate" Text="0" Width="50" TextAlignment="Center" FontSize="12"
                                                                                 BorderThickness="0" Background="Transparent" TextChanged="OnBaCardValueChanged" />
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Margin="0,0,12,0">
                                                                    <TextBlock Text="Complex" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                                                    <Border BorderBrush="#8C5CED" BorderThickness="1" CornerRadius="4" Background="#F8F5FE" Padding="2">
                                                                        <TextBox x:Name="BaNewUR_Complex" Text="0" Width="50" TextAlignment="Center" FontSize="12"
                                                                                 BorderThickness="0" Background="Transparent" TextChanged="OnBaCardValueChanged" />
                                                                    </Border>
