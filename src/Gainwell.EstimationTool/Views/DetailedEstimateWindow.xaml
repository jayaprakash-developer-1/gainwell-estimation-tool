                                        <TextBlock Text="BDD" FontFamily="Arial" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="6" Padding="14,8" Margin="8,0" Opacity="0.95">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="BaStickyWtcText" Text="0.00 hrs" FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="#2199B0" HorizontalAlignment="Center" />
                                        <TextBlock Text="Write System Test Cases" FontFamily="Arial" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="#FFFFFF" CornerRadius="6" Padding="14,8" Margin="8,0" Opacity="0.95">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="BaStickyPvText" Text="0.00 hrs" FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                        <TextBlock Text="Production Validation" FontFamily="Arial" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Background="#FFFFFF" CornerRadius="6" Padding="14,8" Margin="8,0" Opacity="0.95">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="BaStickySysDocText" Text="0.00 hrs" FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="#8C5CED" HorizontalAlignment="Center" />
                                        <TextBlock Text="Sys Doc / Comm Plan" FontFamily="Arial" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="5" Background="#FFFFFF" CornerRadius="6" Padding="14,8" Margin="8,0,0,0" Opacity="0.95">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="BaGrandTotalText" Text="0.00" FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="#1931E3" HorizontalAlignment="Center" />
                                        <TextBlock Text="Grand Total" FontFamily="Arial" FontSize="9" Foreground="#5A6978" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <!-- Bottom row: Complexity Total / Adj Exp Level / Adj Hrs detail -->
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BA GRAND TOTAL" FontFamily="Arial" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Opacity="0.8" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="Complexity Total:" FontFamily="Arial" FontSize="10" Foreground="#00EEAE" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock x:Name="BaGrandTotalCT" Text="0.00" FontFamily="Arial" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="Adj Exp Level:" FontFamily="Arial" FontSize="10" Foreground="#00EEAE" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock x:Name="BaGrandTotalAdjExp" Text="0.00" FontFamily="Arial" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
