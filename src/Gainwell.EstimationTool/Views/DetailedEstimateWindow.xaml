                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="160">
                                                            <TextBlock x:Name="BaNewUR_CT" Text="Complexity Total: 0.00" FontSize="11" Foreground="#2B3A44" />
                                                            <TextBlock x:Name="BaNewUR_AdjExp" Text="Adj Exp Lvl: 0.00" FontSize="11" Foreground="#2B3A44" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="Adj Hrs:" FontSize="10" Foreground="#5A6978" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                <TextBox x:Name="BaNewUR_AdjHrs" Text="0" Width="60" FontSize="11" TextAlignment="Right"
