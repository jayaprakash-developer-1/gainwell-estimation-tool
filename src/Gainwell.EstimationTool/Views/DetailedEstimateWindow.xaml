            <!-- Tab 3: BA Considerations -->
            <TabItem Header="BA Considerations">
                <DockPanel>
                    <!-- STICKY SUMMARY BAR - matching SE Module/Doco tab format -->
                    <Border DockPanel.Dock="Top" CornerRadius="8" Padding="16,12" Margin="8,8,8,0">
