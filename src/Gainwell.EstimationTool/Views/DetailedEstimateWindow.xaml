                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock x:Name="SeAdjustedCharCount" Text="0/4000" FontSize="10" Foreground="#8E99A8" 
                                               HorizontalAlignment="Right" Margin="0,4,4,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
