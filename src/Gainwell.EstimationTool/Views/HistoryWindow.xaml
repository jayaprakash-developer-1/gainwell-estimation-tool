<Window x:Class="Gainwell.EstimationTool.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project History" Height="500" Width="750"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#019681" Offset="0" />
                    <GradientStop Color="#1A6478" Offset="0.5" />
                    <GradientStop Color="#2E307A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="📋 Project History" FontSize="18" FontWeight="SemiBold" Foreground="White" />
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1" Margin="16,12,16,0" Padding="8,6"
                BorderBrush="#D4D7E0" BorderThickness="1" CornerRadius="6" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         BorderThickness="0" Padding="0,2" FontSize="13" VerticalAlignment="Center"
                         TextChanged="OnSearchTextChanged"
                         ToolTip="Filter by Project Name or Change Order (e.g. type 'power' or 'CO-123')">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="PlaceholderBrush" Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Search by project name or change order…" Foreground="#8E99A8" FontSize="13" />
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource PlaceholderBrush}" />
                                </Trigger>
                                <Trigger Property="Text" Value="{x:Null}">
                                    <Setter Property="Background" Value="{StaticResource PlaceholderBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button x:Name="ClearSearchButton" Grid.Column="2" Content="✕"
                        FontSize="11" Foreground="#8E99A8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Visibility="Collapsed" Padding="4,0"
                        Click="OnClearSearchClick" ToolTip="Clear search" />
            </Grid>
        </Border>

        <!-- DataGrid of projects -->
        <DataGrid x:Name="ProjectsGrid" Grid.Row="2" Margin="16,8,16,4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  MouseDoubleClick="OnProjectDoubleClick"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#C2C6D2"
                  RowHeight="36"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#D4D7E0">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#EBEDF5" />
                    <Setter Property="Foreground" Value="#2B3A44" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Padding" Value="8,6" />
                    <Setter Property="BorderBrush" Value="#EBEDF5" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EBEDF5" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EBEDF5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Project Name" Binding="{Binding ProjectName}" Width="200" />
                <DataGridTextColumn Header="Change Order" Binding="{Binding ChangeOrderId}" Width="120" />
                <DataGridTextColumn Header="Total Hours" Binding="{Binding GrandTotalHours, StringFormat=N2}" Width="90" />
                <DataGridTextColumn Header="T-Shirt" Binding="{Binding TShirtSize}" Width="70" />
                <DataGridTextColumn Header="Components" Binding="{Binding Components.Count}" Width="90" />
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate, StringFormat=MM/dd/yyyy}" Width="90" />
                <DataGridTextColumn Header="Modified" Binding="{Binding LastModifiedDate, StringFormat='MM/dd/yyyy h:mm tt'}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,12">
            <Button Content="Load Selected" Padding="16,8" FontSize="13" FontWeight="SemiBold"
                    Background="#019681" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="OnLoadClick" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#019681" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Delete" Padding="16,8" FontSize="13" FontWeight="SemiBold"
                    Foreground="#CC1AC7" Background="White" BorderThickness="1" BorderBrush="#CC1AC7" Cursor="Hand"
                    Click="OnDeleteClick" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="White" CornerRadius="6" BorderThickness="1" BorderBrush="#CC1AC7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Padding="16,8" FontSize="13"
                    Background="#EBEDF5" Foreground="#2B3A44" BorderThickness="0" Cursor="Hand"
                    Click="OnCancelClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#EBEDF5" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
