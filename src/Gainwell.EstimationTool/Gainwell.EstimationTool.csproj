<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Gainwell.EstimationTool</RootNamespace>
    <AssemblyName>Gainwell.EstimationTool</AssemblyName>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <NoWarn>NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0-*" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\logo.png" />
    <Resource Include="Assets\app.ico" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Views\DetailedEstimateWindow1.xaml.cs" />
    <Page Remove="Views\DetailedEstimateWindow1.xaml" />
    <None Include="Views\DetailedEstimateWindow1.xaml" />
    <None Include="Views\DetailedEstimateWindow1.xaml.cs" />
  </ItemGroup>

</Project>
