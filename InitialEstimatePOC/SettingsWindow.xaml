<Window x:Class="InitialEstimatePOC.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InitialEstimatePOC.ViewModels"
        Title="Settings — Weighted Values Manager"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#EBEDF5"
        Icon="Assets/app.ico">

    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2" Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#019681" Offset="0" />
                    <GradientStop Color="#1A6478" Offset="0.5" />
                    <GradientStop Color="#2E307A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="⚙ Weighted Values Settings" FontSize="18" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Edit base hours per component type. Changes take effect immediately in calculations." 
                               FontSize="12" Foreground="#00EEAE" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}"
                            Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="White" BorderBrush="#D4D7E0"
                                        BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextBlock.Foreground="#019681" TextBlock.FontWeight="SemiBold" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="💾 Save All Changes" Command="{Binding SaveAllCommand}"
                            Padding="12,6" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="White" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextBlock.Foreground="#019681" TextBlock.FontWeight="SemiBold" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid with all 66 weighted values -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <DataGrid ItemsSource="{Binding WeightedValueRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E8EAF0"
                      RowHeight="36"
                      FontSize="12"
                      BorderThickness="0"
                      Background="Transparent">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#EBEDF5" />
                        <Setter Property="Foreground" Value="#2B3A44" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="BorderBrush" Value="#EBEDF5" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Component Type" Binding="{Binding DisplayName}" Width="180" IsReadOnly="True" />
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Change Type" Binding="{Binding ChangeType}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Base Hours" Binding="{Binding BaseHours, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="100" 
                                        FontWeight="SemiBold" />
                    <DataGridTextColumn Header="Modified By" Binding="{Binding ModifiedBy}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified, StringFormat='{}{0:MM/dd/yyyy h:mm tt}'}" Width="155" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer status bar -->
        <Border Grid.Row="2" Background="#EBEDF5" Padding="16,10" BorderBrush="#D4D7E0" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#019681" VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="#5A6978">
                    <Run Text="66 weighted values | SQLite storage | " />
                    <Run Text="Edit Base Hours column → Save" FontWeight="SemiBold" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
