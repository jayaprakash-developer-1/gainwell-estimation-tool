                                    <TextBox x:Name="SeModuleAssumptionsTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                             Height="80" Padding="12,10" FontSize="12" BorderBrush="#E5E7EB" Background="#FAFAFA"
                                             MaxLength="1000" TextChanged="OnSeAssumptionTextChanged"
                                             ToolTip="Enter any SE assumptions for this estimate (max 1000 characters)">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock x:Name="SeAssumptionCharCount" Text="0/1000" FontSize="10" Foreground="#9CA3AF" 
                                               HorizontalAlignment="Right" Margin="0,4,4,0" />
                                </StackPanel>
                            </Border>

                            <!-- Adjusted Hours Assumption - Premium -->
                            <Border Background="White" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="#E0E7FF" CornerRadius="4" Padding="6,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="⚡" FontSize="10" />
                                        </Border>
                                        <TextBlock Text="Adjusted Hours Assumption" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBox x:Name="SeAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                             Height="80" Padding="12,10" FontSize="12" BorderBrush="#E5E7EB" Background="#FAFAFA"
                                             MaxLength="1000" TextChanged="OnSeAdjustedTextChanged"
                                             ToolTip="Explain any adjustments made to the estimated hours (max 1000 characters)">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock x:Name="SeAdjustedCharCount" Text="0/1000" FontSize="10" Foreground="#9CA3AF" 
                                               HorizontalAlignment="Right" Margin="0,4,4,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right: Total Panel - Premium Sidebar -->
                    <Border Grid.Column="1" CornerRadius="0" Padding="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FAFBFC" Offset="0" />
                                <GradientStop Color="#F3F4F6" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,16">
                                <!-- Grand Total Hero -->
                                <Border CornerRadius="12" Padding="18,16" Margin="0,0,0,16"
                                        ToolTip="Sum of Development + Promotion + Documentation hours">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#059669" Offset="0" />
                                            <GradientStop Color="#047857" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4" Direction="270" Color="#059669" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="SE GRAND TOTAL" FontSize="10" FontWeight="Bold" Foreground="#A7F3D0" Margin="0,0,0,6" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="SeTotalText" Text="0.00" 
                                                       FontSize="28" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text=" hrs" FontSize="12" Foreground="#A7F3D0" VerticalAlignment="Bottom" Margin="0,0,0,5" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Breakdown Items -->
                                <TextBlock Text="BREAKDOWN" FontSize="9" FontWeight="Bold" Foreground="#9CA3AF" Margin="4,0,0,10" />

                                <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                        ToolTip="Total development hours from all component types">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.04" ShadowDepth="1" Direction="270" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#DCFCE7" CornerRadius="6" Width="32" Height="32" VerticalAlignment="Center">
                                            <TextBlock Text="⚙" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Development" FontSize="11" Foreground="#6B7280" />
                                            <TextBlock x:Name="SeDevTotalText" Text="0.00" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#059669" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                        ToolTip="Hours for code promotion through environments">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.04" ShadowDepth="1" Direction="270" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#E0F2FE" CornerRadius="6" Width="32" Height="32" VerticalAlignment="Center">
                                            <TextBlock Text="🚀" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Promotion" FontSize="11" Foreground="#6B7280" />
                                            <TextBlock x:Name="SePromotionTotalText" Text="0.00" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#059669" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                        ToolTip="Hours for system documentation effort">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.04" ShadowDepth="1" Direction="270" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#FEF3C7" CornerRadius="6" Width="32" Height="32" VerticalAlignment="Center">
                                            <TextBlock Text="📄" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Documentation" FontSize="11" Foreground="#6B7280" />
                                            <TextBlock x:Name="SeDocTotalText" Text="0.00" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#059669" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                        ToolTip="Number of component types with hours entered">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.04" ShadowDepth="1" Direction="270" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#F3E8FF" CornerRadius="6" Width="32" Height="32" VerticalAlignment="Center">
                                            <TextBlock Text="🧩" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Components" FontSize="11" Foreground="#6B7280" />
                                            <TextBlock x:Name="SeComponentCountText" Text="0" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#7C3AED" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: BA Considerations -->
            <TabItem Header="📋 BA Considerations">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- BA Testing/Documentation -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <!-- BA heading with Estimate By on the right -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="BA Estimate — Testing/Documentation" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
                                    <TextBlock Grid.Column="2" Text="Estimate By:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="BaEstimateByTextBox" Grid.Column="3" Padding="8,6" FontSize="13" Width="200" />
                                </Grid>

                                <!-- System Test Cases Grid -->
                                <TextBlock Text="Write System Test Cases" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <DataGrid x:Name="BaTestCasesGrid" AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          BorderThickness="1" BorderBrush="#E5E7EB"
                                          RowHeight="36" MinHeight="150" MaxHeight="400"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridComboBoxColumn Header="Experience" Width="120"
                                            SelectedItemBinding="{Binding ExperienceLevel}" />
                                        <DataGridTextColumn Header="Task" Binding="{Binding TaskName}" Width="250" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Simple" Binding="{Binding SimpleCount}" Width="80" />
                                        <DataGridTextColumn Header="Moderate" Binding="{Binding ModerateCount}" Width="80" />
                                        <DataGridTextColumn Header="Complex" Binding="{Binding ComplexCount}" Width="80" />
                                        <DataGridTextColumn Header="Very Complex" Binding="{Binding VeryComplexCount}" Width="100" />
                                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat='{}{0:N2}'}" Width="80" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Adjusted" Binding="{Binding AdjustedHours, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Production Validation -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Production Validation" Style="{StaticResource SectionHeader}" />
                                <DataGrid x:Name="BaProductionValidationGrid" AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          BorderThickness="1" BorderBrush="#E5E7EB"
                                          RowHeight="36" MinHeight="100" MaxHeight="300"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridComboBoxColumn Header="Experience" Width="120"
                                            SelectedItemBinding="{Binding ExperienceLevel}" />
                                        <DataGridTextColumn Header="Validation Type" Binding="{Binding TaskName}" Width="200" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Hours" Binding="{Binding Hours, StringFormat='{}{0:N2}'}" Width="80" />
                                        <DataGridTextColumn Header="Adjusted" Binding="{Binding AdjustedHours, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- BA Totals -->
                        <Border Style="{StaticResource CardBorder}">
                            <Border Background="#EFF6FF" CornerRadius="6" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Total BA Hours:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="BaTotalText" Grid.Column="1" Text="0.00" 
                                               FontSize="16" FontWeight="Bold" Foreground="#2563EB" />
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Assumptions -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Assumptions" Style="{StaticResource SectionHeader}" />
                                <TextBox x:Name="BaAssumptionsDetailTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="80" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Adjusted Hours Assumption -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Adjusted Hours Assumption" Style="{StaticResource SectionHeader}" />
                                <TextBox x:Name="BaAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="80" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: Collaboration/Quality -->
            <TabItem Header="🤝 Collaboration/Quality">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <!-- Collaboration heading with Estimate By on the right -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Collaboration — Quality" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
                                    <TextBlock Grid.Column="2" Text="Estimate By:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="CollabEstimateByTextBox" Grid.Column="3" Padding="8,6" FontSize="13" Width="200" />
                                </Grid>

                                <!-- WPRs -->
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Headers -->
                                        <TextBlock Grid.Column="1" Text="Count" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Hours" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="Attendees" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="Total" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" />

                                        <!-- WPR Meetings -->
                                        <TextBlock Grid.Row="1" Text="Walkthrough/Work Product Reviews" FontSize="13" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <TextBox x:Name="WprCountTextBox" Grid.Row="1" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,8,4,0" />
                                        <TextBox x:Name="WprHoursTextBox" Grid.Row="1" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,8,4,0" />
                                        <TextBox x:Name="WprAttendeesTextBox" Grid.Row="1" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,8,4,0" />
                                        <TextBlock x:Name="WprTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8,0,0" />

                                        <!-- WPR Prep -->
                                        <TextBlock Grid.Row="2" Text="  WPR Preparation per person" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="WprPrepHoursTextBox" Grid.Row="2" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" />
                                        <TextBlock x:Name="WprPrepTotalText" Grid.Row="2" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Client Meetings -->
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Client Meetings" FontSize="13" VerticalAlignment="Center" />
                                        <TextBox x:Name="ClientMtgCountTextBox" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBox x:Name="ClientMtgHoursTextBox" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBox x:Name="ClientMtgAttendeesTextBox" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBlock x:Name="ClientMtgTotalText" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Text="  Client Meeting Prep per person" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="ClientMtgPrepHoursTextBox" Grid.Row="1" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" />
                                        <TextBlock x:Name="ClientMtgPrepTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Internal Meetings -->
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Internal Meetings" FontSize="13" VerticalAlignment="Center" />
                                        <TextBox x:Name="InternalMtgCountTextBox" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBox x:Name="InternalMtgHoursTextBox" Grid.Column="2" Text="1" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBox x:Name="InternalMtgAttendeesTextBox" Grid.Column="3" Text="0" Padding="6,4" FontSize="12" Margin="4,0" />
                                        <TextBlock x:Name="InternalMtgTotalText" Grid.Column="4" Text="0.00" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Text="  Internal Meeting Prep per person" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBox x:Name="InternalMtgPrepHoursTextBox" Grid.Row="1" Grid.Column="2" Text="0" Padding="6,4" FontSize="12" Margin="4,6,4,0" />
                                        <TextBlock x:Name="InternalMtgPrepTotalText" Grid.Row="1" Grid.Column="4" Text="0.00" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Consultant/Mentor -->
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Consultant/Mentor Effort" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <DataGrid x:Name="ConsultantGrid" AutoGenerateColumns="False"
                                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                  BorderThickness="1" BorderBrush="#E5E7EB"
                                                  RowHeight="32" MinHeight="80" MaxHeight="200">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Person Name" Binding="{Binding Name}" Width="200" />
                                                <DataGridTextColumn Header="Hours" Binding="{Binding Hours}" Width="100" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Create Estimates & PM -->
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Create Detailed Estimate (hrs):" FontSize="13" VerticalAlignment="Center" />
                                        <TextBox x:Name="CreateDetailEstHoursTextBox" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,0" />

                                        <TextBlock Grid.Row="1" Text="Create Final Estimate (hrs):" FontSize="13" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <TextBox x:Name="CreateFinalEstHoursTextBox" Grid.Row="1" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,8,4,0" />

                                        <TextBlock Grid.Row="2" Text="Project Manager Effort (hrs):" FontSize="13" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <TextBox x:Name="PmEffortHoursTextBox" Grid.Row="2" Grid.Column="1" Text="0" Padding="6,4" FontSize="12" Margin="4,8,4,0" />
                                    </Grid>
                                </Border>

                                <!-- Collaboration Total -->
                                <Border Background="#FFF7ED" CornerRadius="6" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Total Collaboration/Quality Hours:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CollabTotalText" Grid.Column="1" Text="0.00" 
                                                   FontSize="16" FontWeight="Bold" Foreground="#EA580C" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Assumptions -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Assumptions" Style="{StaticResource SectionHeader}" />
                                <TextBox x:Name="CollabAssumptionsDetailTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="80" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Adjusted Hours Assumption -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Adjusted Hours Assumption" Style="{StaticResource SectionHeader}" />
                                <TextBox x:Name="CollabAdjustedHrsCommentTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                                         Height="80" Padding="8,6" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
