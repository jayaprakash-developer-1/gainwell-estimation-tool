<Window x:Class="InitialEstimatePOC.DetailedEstimateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detailed Estimate" 
        Height="1000" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F7FA"
        Icon="Assets/app.ico"
        KeyboardNavigation.TabNavigation="Cycle">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="OnSaveCommand" />
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}" Executed="OnUndoCommand" />
    </Window.CommandBindings>

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2" Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1A1A2E" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A52E0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#6C63FF" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Padding="24,16" Margin="8,8,8,0" CornerRadius="8,8,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00857C" Offset="0" />
                    <GradientStop Color="#006B64" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <Image Source="Assets/logo.png" Height="36" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Detailed Estimate" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="16,8" Margin="8,0" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TotalHoursKpi" Text="0.00 Hrs" FontSize="18" FontWeight="Bold" Foreground="#00857C" HorizontalAlignment="Center" />
                        <TextBlock Text="Total Hours" FontSize="10" Foreground="#374151" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🏠 Home" Style="{StaticResource GhostButton}" 
                            Click="OnHomeClick" Margin="4,0"
                            Foreground="White" BorderBrush="#4DB6AC" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ ESTIMATE TAB NAVIGATION ═══════════ -->
        <Border Grid.Row="1" Margin="8,0,8,0" Padding="4,4" Background="#F0F0F5" CornerRadius="0,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Navigation Tabs (Left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <!-- Initial Estimate Tab -->
                    <Border x:Name="InitialTab" Background="Transparent" CornerRadius="6" Padding="16,8" Margin="4,0"
                            Cursor="Hand" MouseLeftButtonDown="OnInitialTabClick">
                        <TextBlock Text="Initial Estimate" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" />
                    </Border>
                    <!-- Detailed Estimate Tab (Active) -->
                    <Border Background="#6C63FF" CornerRadius="6" Padding="16,8" Margin="4,0">
                        <TextBlock Text="Detailed Estimate" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                    <!-- Final Estimate Tab -->
                    <Border Background="Transparent" CornerRadius="6" Padding="16,8" Margin="4,0"
                            Cursor="Hand" MouseLeftButtonDown="OnFinalTabClick">
                        <TextBlock Text="Final Estimate" FontSize="12" FontWeight="SemiBold" Foreground="#9CA3AF" />
                    </Border>
                </StackPanel>

                <!-- Save & Settings Buttons (Right) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="1" Background="#D1D5DB" Margin="8,4" />
                    <Button Content="💾 Save" Style="{StaticResource GhostButton}" 
                            Click="OnSaveClick" Margin="4,0" ToolTip="Ctrl+S" />
                    <Button Content="⚙ Settings" Style="{StaticResource GhostButton}" 
                            Click="OnSettingsClick" Margin="4,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control for 4 Sub-Pages -->
        <TabControl Grid.Row="2" Margin="8,8,8,8" BorderThickness="0" Background="Transparent"
                   SelectionChanged="OnTabSelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,10" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}" 
                                        Background="Transparent" CornerRadius="6,6,0,0"
                                        BorderThickness="0,0,0,3" BorderBrush="Transparent" Margin="2,0">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#00857C" />
                                        <Setter Property="Foreground" Value="#00857C" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Summary -->
            <TabItem Header="📊 Estimate Summary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Project Header Card with gradient accent -->
                        <Border CornerRadius="12" Margin="8" Padding="0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.06" ShadowDepth="3" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <!-- Top accent bar -->
                                <Border Height="4" VerticalAlignment="Top" CornerRadius="12,12,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00857C" Offset="0" />
                                            <GradientStop Color="#6C63FF" Offset="0.5" />
                                            <GradientStop Color="#EA580C" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="PROJECT NAME" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,6" />
                                            <TextBox x:Name="ProjectNameTextBox" Padding="10,8" FontSize="13" IsReadOnly="True" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                                     ToolTip="The name of the project being estimated">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Text="CHANGE ORDER / DEFECT" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,6" />
                                            <TextBox x:Name="ChangeOrderTextBox" Padding="10,8" FontSize="13" IsReadOnly="True" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                                     ToolTip="Change Order ID or Defect number associated with this estimate">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                            <TextBlock Text="DATE (MM/DD/YYYY)" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,6" />
                                            <TextBox x:Name="ActualHoursDateTextBox" Padding="10,8" FontSize="13" BorderBrush="#E5E7EB" BorderThickness="1"
                                                     ToolTip="Date when the actual hours were recorded (format: MM/DD/YYYY)">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ═══════ KPI METRIC CARDS ═══════ -->
                        <Grid Margin="8,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Actual Hours Card -->
                            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Enter the total actual hours spent on this project">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#F3F4F6" HorizontalAlignment="Left" />
                                        <TextBlock Text="⏱" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="ACTUAL HOURS" FontSize="9" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,4" />
                                    <TextBox x:Name="ActualHoursTextBox" Text="0" Padding="0" FontSize="20" FontWeight="Bold" Foreground="#374151" 
                                             BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Left" TextChanged="OnSummaryFieldChanged" />
                                </StackPanel>
                            </Border>

                            <!-- SE Hours Card -->
                            <Border Grid.Column="1" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total hours estimated by Software Engineering (auto-calculated from SE tab)">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FDF4" Offset="0" />
                                        <GradientStop Color="#DCFCE7" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#BBF7D0" HorizontalAlignment="Left" />
                                        <TextBlock Text="🔧" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="SE HOURS" FontSize="9" FontWeight="Bold" Foreground="#166534" Margin="0,0,0,4" />
                                    <TextBlock x:Name="SeHoursKpi" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#16A34A" />
                                </StackPanel>
                            </Border>

                            <!-- BA Hours Card -->
                            <Border Grid.Column="2" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total hours estimated by Business Analyst (auto-calculated from BA tab)">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EFF6FF" Offset="0" />
                                        <GradientStop Color="#DBEAFE" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#BFDBFE" HorizontalAlignment="Left" />
                                        <TextBlock Text="📋" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="BA HOURS" FontSize="9" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,4" />
                                    <TextBlock x:Name="BaHoursKpi" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#2563EB" />
                                </StackPanel>
                            </Border>

                            <!-- Collaboration Hours Card -->
                            <Border Grid.Column="3" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Total Collaboration/Quality hours including meetings, WPRs, and mentoring">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF7ED" Offset="0" />
                                        <GradientStop Color="#FFEDD5" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#FED7AA" HorizontalAlignment="Left" />
                                        <TextBlock Text="🤝" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="COLLAB HOURS" FontSize="9" FontWeight="Bold" Foreground="#9A3412" Margin="0,0,0,4" />
                                    <TextBlock x:Name="CollabHoursKpi" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#EA580C" />
                                </StackPanel>
                            </Border>

                            <!-- Total Estimate Card -->
                            <Border Grid.Column="4" CornerRadius="10" Padding="16,14" Margin="4"
                                    ToolTip="Grand total of all estimated hours including PM reserve">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FDFA" Offset="0" />
                                        <GradientStop Color="#CCFBF1" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="3" Direction="270" />
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Ellipse Width="32" Height="32" Fill="#99F6E4" HorizontalAlignment="Left" />
                                        <TextBlock Text="✓" FontSize="16" FontWeight="Bold" Foreground="#0D9488" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="TOTAL ESTIMATE" FontSize="9" FontWeight="Bold" Foreground="#134E4A" Margin="0,0,0,4" />
                                    <TextBlock x:Name="TotalWithReserveText" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="#00857C" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- PM Reserve Row -->
                        <Border Background="White" CornerRadius="10" Padding="16,12" Margin="12,0,12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.04" ShadowDepth="1" Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#EDE9FE" CornerRadius="6" Padding="8,4" Margin="0,0,12,0">
                                        <TextBlock Text="PM" FontSize="10" FontWeight="Bold" Foreground="#7C3AED" />
                                    </Border>
                                    <TextBlock Text="Project Management Reserve" FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox x:Name="PmReserveTextBox" Text="5" Width="48" Padding="6,4" FontSize="12" TextAlignment="Center" 
                                             BorderBrush="#D1D5DB" TextChanged="OnSummaryFieldChanged"
                                             ToolTip="Percentage of total hours to reserve for Project Management (typically 5-10%)">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock Text=" %" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="2,0,16,0" />
                                    <Border Background="#F5F3FF" CornerRadius="6" Padding="10,4">
                                        <TextBlock x:Name="PmReserveHoursText" Text="0.00 hrs" FontSize="13" FontWeight="Bold" Foreground="#6C63FF" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ═══════ TEAM / ESTIMATED BY ═══════ -->
                        <Border Background="White" CornerRadius="10" Padding="20,16" Margin="12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.05" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="TEAM" FontSize="10" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="8" Padding="12,10" Margin="0,0,6,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="SE ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#6B7280" />
                                            </StackPanel>
                                            <TextBox x:Name="EstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="8" Padding="12,10" Margin="3,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#2563EB" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="BA ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#6B7280" />
                                            </StackPanel>
                                            <TextBox x:Name="BaEstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#F9FAFB" CornerRadius="8" Padding="12,10" Margin="6,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="8" Height="8" Fill="#EA580C" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="COLLAB ESTIMATE BY" FontSize="9" FontWeight="Bold" Foreground="#6B7280" />
                                            </StackPanel>
                                            <TextBox x:Name="CollabEstimatedByTextBox" Padding="8,6" FontSize="12" IsReadOnly="True" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══════ ASSUMPTIONS ═══════ -->
                        <Border Background="White" CornerRadius="10" Padding="20,16" Margin="12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.05" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="ASSUMPTIONS" FontSize="10" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,14" />
                                <!-- SE Assumption -->
                                <Border Background="#F0FDF4" CornerRadius="8" Padding="14,10" Margin="0,0,0,10" BorderBrush="#BBF7D0" BorderThickness="1,1,1,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="SE Assumption" FontSize="11" FontWeight="SemiBold" Foreground="#166534" />
                                        </StackPanel>
                                        <TextBlock x:Name="SummarySeAssumptionText" TextWrapping="Wrap" FontSize="12" Foreground="#374151" FontStyle="Italic" />
                                    </StackPanel>
                                </Border>
                                <!-- BA Assumption -->
