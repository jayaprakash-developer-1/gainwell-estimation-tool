<Window x:Class="InitialEstimatePOC.SeComponentDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InitialEstimatePOC.Models"
        Title="Component Detail" Width="1100" Height="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#00857C" Padding="16,10">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ComponentTypeHeader" Text="Component Type" 
                               FontSize="16" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="ComponentSubHeader" Text="Enter module details (default 5 rows)" 
                               FontSize="11" Foreground="#B2DFDB" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add Row Button -->
        <Border Grid.Row="1" Padding="12,8">
            <Button Content="+ Add Row" Click="OnAddRow" HorizontalAlignment="Left"
                    Padding="12,6" FontSize="12" Cursor="Hand"
                    Background="#00857C" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

        <!-- Module Entries DataGrid -->
        <DataGrid Grid.Row="2" x:Name="ModuleGrid" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#E5E7EB"
                  RowHeight="34" Margin="12,0,12,0"
                  VerticalScrollBarVisibility="Auto"
                  SelectionUnit="CellOrRowHeader"
                  CellEditEnding="OnCellEditEnding">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Experience Level" Width="120"
                    SelectedItemBinding="{Binding ExperienceLevel, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Module Name" Binding="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                <DataGridComboBoxColumn Header="New/Existing" Width="100"
                    SelectedItemBinding="{Binding ComponentStatus, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Simple" Binding="{Binding SimpleCount, UpdateSourceTrigger=PropertyChanged}" Width="65" />
                <DataGridTextColumn Header="Moderate" Binding="{Binding ModerateCount, UpdateSourceTrigger=PropertyChanged}" Width="75" />
                <DataGridTextColumn Header="Complex" Binding="{Binding ComplexCount, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Complexity Total" Binding="{Binding ComplexityTotal, StringFormat='{}{0:N2}'}" Width="105" IsReadOnly="True" />
                <DataGridTextColumn Header="Adj Exp Level" Binding="{Binding AdjustedExpLevel, StringFormat='{}{0:N2}'}" Width="95" IsReadOnly="True" />
                <DataGridTextColumn Header="Adjusted Hrs" Binding="{Binding AdjustedHrs, StringFormat='{}{0:N2}', UpdateSourceTrigger=PropertyChanged}" Width="90" />
                <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Totals -->
        <Border Grid.Row="3" Margin="12,8,12,0" Background="#F0FDF4" CornerRadius="6" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Totals:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Complexity: " FontSize="12" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBlock x:Name="ComplexityTotalText" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Adj Exp: " FontSize="12" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBlock x:Name="AdjExpTotalText" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#0E7490" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="Grand Total: " FontSize="12" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBlock x:Name="GrandTotalText" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#00857C" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
            <Button Content="Cancel" Padding="16,8" FontSize="12" Margin="0,0,8,0"
                    Click="OnCancel" Background="#F3F4F6" BorderBrush="#D1D5DB" />
            <Button Content="✓ Save" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                    Click="OnSave" Background="#00857C" Foreground="White" BorderBrush="#006B64">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
