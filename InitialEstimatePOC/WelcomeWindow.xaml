<Window x:Class="InitialEstimatePOC.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estimation Tool" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="Assets/app.ico">

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="32" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" Opacity="0.08" ShadowDepth="4" Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#6C63FF" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="28,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A52E0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="28,12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Padding="32,24" Margin="24,24,24,0" CornerRadius="12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00857C" Offset="0" />
                    <GradientStop Color="#006B64" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/logo.png" Height="40" Margin="0,0,16,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Estimation Tool" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Component-Based Project Estimation" FontSize="13" Foreground="#C7D2FE" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Left: Project Form -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Project Information" FontSize="18" FontWeight="Bold" 
                               Foreground="#1A1A2E" Margin="0,0,0,24" />

                    <!-- Project Name -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Project Name" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="ProjectNameTextBox" Style="{StaticResource FieldTextBox}" />
                    </StackPanel>

                    <!-- Change Order -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Change Order / Defect #" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="ChangeOrderTextBox" Style="{StaticResource FieldTextBox}" />
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="DescriptionTextBox" Style="{StaticResource FieldTextBox}" 
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Create New" Style="{StaticResource PrimaryButton}" 
                                Click="OnCreateClick" Margin="0,0,12,0" />
                        <Button Content="Open Existing" Style="{StaticResource GhostButton}" 
                                Click="OnOpenClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right: Recent Projects -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Recent Projects" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#1A1A2E" Margin="0,0,0,12" />
                    <ListBox x:Name="RecentProjectsList" BorderThickness="0" 
                             SelectionChanged="OnRecentProjectSelected"
                             MaxHeight="350">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock FontSize="11" Foreground="#6B7280">
                                        <Run Text="{Binding ChangeOrderId}" />
                                        <Run Text=" • " />
                                        <Run Text="{Binding LastModifiedDate, StringFormat='{}{0:MMM dd, yyyy}'}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="NoProjectsText" Text="No saved projects yet."
                               FontSize="12" Foreground="#9CA3AF" Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
